# AUOTAM Email Automation - Environment Variables

# PostgreSQL (AUOTAM CRM) — when set, persistence uses DB instead of CSV/JSONL files.
# DATABASE_URL=postgresql://auotam:password@host:5432/auotam_crm

# Email provider: SES is default for AUOTAM production.
EMAIL_PROVIDER=ses
# Optional — only if you explicitly enable SendGrid:
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=

# Cost guard (scheduler): Month-to-date AWS spend via Cost Explorer (us-east-1 API)
COST_GUARD_CEILING_USD=50
COST_GUARD_LOG_PATH=data/logs/cost_guard.jsonl
# DISABLE_COST_GUARD=1
BASE_URL=https://auotam.net
# Verified SES identity (must match AWS SES). AUOTAM_FROM_EMAIL wins over FROM_EMAIL.
AUOTAM_FROM_EMAIL=hello@auotam.net
FROM_EMAIL=hello@auotam.net
REPLY_TO=sales@auotam.com
AUOTAM_FROM_NAME=Govind Chauhan

# Suppression + throttles
SUPPRESSION_DIR=data/suppression
MAX_PER_DAY_PER_DOMAIN=50

# Webhook server (for SendGrid events + unsubscribe)
PORT=8080
SENDGRID_WEBHOOK_SECRET=rotate_me

# AWS (SES + Cost Explorer for scheduler guard)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
SES_CONFIGURATION_SET=

# Sending controls
AUOTAM_DAILY_TARGET=6000
AUOTAM_START_HOUR_EST=9
AUOTAM_END_HOUR_EST=17
AUOTAM_SENDS_PER_SECOND=1
